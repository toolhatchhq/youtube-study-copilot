{
  "manifest_version": 3,
  "name": "YouTube Study Copilot",
  "short_name": "Study Copilot",
  "version": "0.5.0",
  "description": "Turn YouTube lessons into notes, flashcards, quizzes, and exportable study packs.",
  "minimum_chrome_version": "114",
  "homepage_url": "https://toolhatchhq.github.io/youtube-study-copilot/",
  "permissions": [
    "storage",
    "tabs",
    "scripting",
    "sidePanel"
  ],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://*.i.posthog.com/*",
    "https://*.ingest.sentry.io/*"
  ],
  "optional_host_permissions": [
    "https://api.lemonsqueezy.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "options_page": "welcome.html",
  "action": {
    "default_title": "YouTube Study Copilot",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
